# انسخ هذا الملف باسم .env واملأ القيم الحقيقية — لا ترفع .env أبداً لـGitHub

# --- المطلوب لاختبار test_drive_instagram.py فقط ---
# ملاحظة مهمة: هذان سرّان مختلفان بصيغتين مختلفتين تماماً، لا تخلطهما:

# 1) لـ Google Sheets فقط — Service Account حقيقي (فيه private_key و client_email)
GOOGLE_SERVICE_ACCOUNT_JSON={"type": "service_account", "...": "..."}

# 2) لـ Google Drive فقط — محتوى token.json الناتج من تسجيل دخول OAuth
#    (فيه client_id, client_secret, refresh_token, token)
#    السبب: حسابات Service Account لا تملك حصة تخزين خاصة بها على Drive (0 بايت)
GOOGLE_OAUTH_TOKEN_JSON={"client_id": "...", "client_secret": "...", "refresh_token": "...", "token": "...", "token_uri": "https://oauth2.googleapis.com/token"}

GOOGLE_DRIVE_FOLDER_ID=
IG_ACCESS_TOKEN=
IG_BUSINESS_ID=

# --- إضافية، مطلوبة لباقي النظام لاحقاً (Phase 3/4) ---
GOOGLE_SHEET_ID=
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
PIXABAY_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
FB_APP_ID=
FB_APP_SECRET=
GH_PAT=
GH_REPO=Mohammed-163/instagram-autopublish
